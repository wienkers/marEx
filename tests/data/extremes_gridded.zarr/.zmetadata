{
    "metadata": {
        ".zattrs": {
            "method_anomaly": "shifting_baseline",
            "method_extreme": "hobday_extreme",
            "preprocessing_steps": [
                "Rolling climatology using 15 years",
                "Smoothed with 21-day window",
                "Day-of-year thresholds with 11 day window"
            ],
            "smooth_days_baseline": 21,
            "threshold_percentile": 95,
            "window_days_hobday": 11,
            "window_year_baseline": 15
        },
        ".zgroup": {
            "zarr_format": 2
        },
        "extreme_events/.zarray": {
            "chunks": [
                2,
                180,
                360
            ],
            "compressor": {
                "blocksize": 0,
                "clevel": 5,
                "cname": "lz4",
                "id": "blosc",
                "shuffle": 1
            },
            "dtype": "|i1",
            "fill_value": null,
            "filters": null,
            "order": "C",
            "shape": [
                32,
                180,
                360
            ],
            "zarr_format": 2
        },
        "extreme_events/.zattrs": {
            "_ARRAY_DIMENSIONS": [
                "time",
                "lat",
                "lon"
            ],
            "dtype": "bool"
        },
        "lat/.zarray": {
            "chunks": [
                721
            ],
            "compressor": null,
            "dtype": "<f8",
            "fill_value": "NaN",
            "filters": null,
            "order": "C",
            "shape": [
                180
            ],
            "zarr_format": 2
        },
        "lat/.zattrs": {
            "_ARRAY_DIMENSIONS": [
                "lat"
            ],
            "axis": "Y",
            "long_name": "latitude",
            "standard_name": "latitude",
            "units": "degrees_north"
        },
        "lon/.zarray": {
            "chunks": [
                1440
            ],
            "compressor": null,
            "dtype": "<f8",
            "fill_value": "NaN",
            "filters": null,
            "order": "C",
            "shape": [
                360
            ],
            "zarr_format": 2
        },
        "lon/.zattrs": {
            "_ARRAY_DIMENSIONS": [
                "lon"
            ],
            "axis": "X",
            "long_name": "longitude",
            "standard_name": "longitude",
            "units": "degrees_east"
        },
        "mask/.zarray": {
            "chunks": [
                180,
                360
            ],
            "compressor": {
                "blocksize": 0,
                "clevel": 5,
                "cname": "lz4",
                "id": "blosc",
                "shuffle": 1
            },
            "dtype": "|i1",
            "fill_value": null,
            "filters": null,
            "order": "C",
            "shape": [
                180,
                360
            ],
            "zarr_format": 2
        },
        "mask/.zattrs": {
            "_ARRAY_DIMENSIONS": [
                "lat",
                "lon"
            ],
            "dtype": "bool",
            "long_name": "sea water potential temperature",
            "param": "18.4.10",
            "standard_name": "sea_water_potential_temperature",
            "units": "C"
        },
        "time/.zarray": {
            "chunks": [
                28124
            ],
            "compressor": null,
            "dtype": "<f8",
            "fill_value": "NaN",
            "filters": null,
            "order": "C",
            "shape": [
                32
            ],
            "zarr_format": 2
        },
        "time/.zattrs": {
            "_ARRAY_DIMENSIONS": [
                "time"
            ],
            "calendar": "gregorian",
            "standard_name": "time",
            "units": "minutes since 1950-01-01"
        }
    },
    "zarr_consolidated_format": 1
}